# U-DIG-IT Backend Environment Configuration
# Copy this file to .env and populate with real values

# Application Configuration
APP_NAME="U-DIG-IT API"
BACKEND_ENVIRONMENT="development"
BACKEND_LOG_LEVEL="info"

# Database Configuration
DATABASE_URL="sqlite:///./u_dig_it.db"
# For production, use PostgreSQL:
# DATABASE_URL="postgresql://username:password@localhost:5432/udigit_prod"

# Security Configuration (CHANGE THESE IN PRODUCTION!)
JWT_SECRET="your-super-secure-jwt-secret-key-here-minimum-32-characters"
JWT_EXPIRES_IN="24h"
REFRESH_TOKEN_SECRET="your-super-secure-refresh-token-secret-here-minimum-32-characters"
REFRESH_TOKEN_EXPIRES_IN="14d"

# CORS Configuration
CORS_ORIGIN="http://localhost:5173,http://localhost:3000"

# Monitoring & Observability
BACKEND_SENTRY_DSN=""

# Storage Configuration (Optional)
STORAGE_PROVIDER=""
STORAGE_BUCKET=""

# Analytics Configuration (Optional)
MIXPANEL_API_KEY=""
SEGMENT_JS_WRITE_KEY=""

# OpenAI Integration (Optional)
OPENAI_API_KEY=""
AGENTS_API_KEY=""

# Email Configuration (Optional)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""

# Payment Processing (Optional)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# External Services (Optional)
REDIS_URL=""
ELASTICSEARCH_URL=""

