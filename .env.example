# ========= CORE KEYS =========
# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_openai_org_id_here

# GitHub (for submodules, automation, Actions)
GITHUB_TOKEN=your_github_token_here

# Cursor IDE / Codex Agent
CODEX_AGENT_MODE=dev
CODEX_AGENT_LOG_LEVEL=info

# ========= DATABASES =========
# Postgres (main DB for the equipment rental app)
DATABASE_URL=postgresql://user:password@localhost:5432/codex_meta

# Redis (caching + async jobs)
REDIS_URL=redis://localhost:6379/0

# ========= AUTH & USERS =========
# JWT (auth for rental platform)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Refresh Tokens
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRES_IN=30d
# OAuth (Google, GitHub, etc.)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ========= STORAGE =========
# S3 / GCS (media uploads for rental items, docs)
STORAGE_PROVIDER=s3
STORAGE_BUCKET=your_bucket_name
STORAGE_ACCESS_KEY=your_storage_access_key
STORAGE_SECRET_KEY=your_storage_secret_key
STORAGE_REGION=your_storage_region

# ========= EMAIL & COMMS =========
# SMTP / SendGrid / Postmark
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=your_email_api_key
EMAIL_FROM=no-reply@codex-meta.com

# Realtime & Voice (for Whisper + Realtime APIs)
REALTIME_API_KEY=your_realtime_api_key
VOICE_AGENT_KEY=your_voice_agent_key

# ========= ANALYTICS =========
# Mixpanel / Segment
MIXPANEL_API_KEY=your_mixpanel_api_key

# Segment Sources (optional — for different platforms)
SEGMENT_JS_WRITE_KEY=your_segment_js_website_write_key
SEGMENT_NODE_WRITE_KEY=your_segment_node_server_write_key

# Agents SDK
AGENTS_API_KEY=your_agents_api_key

# Whisper (speech → text)
WHISPER_API_KEY=your_whisper_api_key

# Tiktoken (token counting for cost dashboards)
TIKTOKEN_CONFIG=default

# ========= PAYMENT =========
# Stripe / PayPal for equipment rentals
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# ========= SECURITY =========
# Rate limiting, session security
RATE_LIMIT=100
SESSION_SECRET=your_session_secret
CORS_ORIGIN=http://localhost:3000

# ========= OBSERVABILITY =========

# Frontend Environment Configuration

# Logging & Monitoring
VITE_FRONTEND_SENTRY_DSN=https://<your-frontend-dsn>
VITE_FRONTEND_LOG_LEVEL=info

# Performance & Observability
VITE_FRONTEND_METRICS_ENABLED=true
VITE_FRONTEND_TRACES_SAMPLE_RATE=1.0

# Deployment Environment
VITE_FRONTEND_ENVIRONMENT=development
VITE_API_BASE_URL=http://localhost:8000

# Backend Environment Configuration

# Logging & Monitoring
BACKEND_SENTRY_DSN=https://<your-backend-dsn>
BACKEND_LOG_LEVEL=info

# Performance & Observability
BACKEND_METRICS_ENABLED=true
BACKEND_TRACES_SAMPLE_RATE=1.0

# Deployment Environment
BACKEND_ENVIRONMENT=development


# ========= UNLEASH FEATURE FLAGS =========
FEATURE_FLAG_PROVIDER=unleash

# Backend-only token (full access)
FEATURE_FLAG_KEY=default:development.backend_token_here
FEATURE_FLAG_URL=http://localhost:4242/api

# Frontend-only token (restricted access)
VITE_FEATURE_FLAG_KEY=default:development.frontend_token_here
VITE_FEATURE_FLAG_URL=http://localhost:4242/api/frontend

# ========= GLOBAL EXPANSION =========
# Multi-language / localization
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,fr,es,de
FX_API_KEY=your_forex_api_key
